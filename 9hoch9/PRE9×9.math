  ENGINE.BIND: 9x9 + 3x3 + 6e6D

  9x9.IN: horizontal
  9x9.OUT: vertikal
  9x9.BREITE: 9
  9x9.TIEFE: 9
  9x9.MYSTER: aktiv

  3x3.AXIOM: DA / NE / BEN
