  6e6D.ABLEITUNG: U
  6e6D.KERNEL: Tiefen‑Kernel
  6e6D.ZOOM: 6 → 12 → 18

  SYNC.ALL: TRUE
  SYNC.ULTRA: TRUE
  SYNC.ENGINE: TRUE
